# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── Voice settings (Kokoro-first, low-latency) ──────────────────────────────
# Default Gandalf stack: Kokoro British male, with optional F5 reference clone.
GANDALF_DEFAULT_VOICE=bm_george
GANDALF_FORCE_VOICE_PROFILE=
GANDALF_STREAM_CLONE=0
GANDALF_CLONE_TARGETS=
GANDALF_AUTO_REF_TEXT=0
GANDALF_PREWARM_F5=0
GANDALF_F5_STARTUP_TIMEOUT=180
GANDALF_F5_TIMEOUT=30
GANDALF_F5_MAX_FAILS=2

# Kokoro voice configuration
# American voices need KOKORO_LANG=a, British voices need KOKORO_LANG=b.
KOKORO_VOICE=bm_george
KOKORO_SPEED=0.84
KOKORO_LANG=b

# Voice websocket payload limits (defensive hardening)
GANDALF_VOICE_MAX_B64_CHARS=8000000
GANDALF_VOICE_MAX_RAW_BYTES=5000000
GANDALF_VOICE_MIN_SAMPLE_RATE=8000
GANDALF_VOICE_MAX_SAMPLE_RATE=48000

# ── Character FX chain ───────────────────────────────────────────────────────
# Applied on top of Kokoro output (GANDALF_MEGATRON=1 enables the chain).
GANDALF_MEGATRON=1
GANDALF_PITCH=-1.5
GANDALF_FORMANT=0.93
GANDALF_LOW_BOOST=4.0
GANDALF_LOW_CUTOFF=300
GANDALF_SUB_MIX=0.0
GANDALF_DRIVE=1.6
GANDALF_VOC_MIX=0.0
GANDALF_VOC_BASE=380
GANDALF_RING_HZ=0.0
GANDALF_RING_DEPTH=0.0
GANDALF_COMB_MS=2.0
GANDALF_COMB_FB=0.0
GANDALF_COMB_MIX=0.0
GANDALF_CRUSH_MIX=0.0
GANDALF_CRUSH_BITS=16
GANDALF_CRUSH_DECIM=1
GANDALF_CHEST_HZ=230
GANDALF_CHEST_DB=5.0
GANDALF_CHEST_Q=2.0
GANDALF_BITE_HZ=3200
GANDALF_BITE_DB=2.5
GANDALF_BITE_Q=1.5
GANDALF_SIB_HZ=7500
GANDALF_SIB_DB=2.0
GANDALF_VERB_MS=65
GANDALF_VERB_FB=0.32
GANDALF_VERB_MIX=0.10

# Path to ffmpeg bin/ directory (used by voice pipeline).
# Leave blank if ffmpeg is already on your system PATH.
FFMPEG_DIR=C:\ffmpeg\bin\ffmpeg-master-latest-win64-gpl-shared\ffmpeg-master-latest-win64-gpl-shared\bin

# ── API keys ─────────────────────────────────────────────────────────────────
# Required: Anthropic Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Tavily API for internet search — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_ALLOWED_USER_ID=<your-telegram-user-id>

# ── Paths (machine-specific) ──────────────────────────────────────────────────
# Root of your QuantitativeValue project (for portfolio CSV + EDGAR screener).
QV_PATH=C:\Users\<you>\QuantitativeValue

# Path to Gandalf GitHub App private key (for autonomous bot commits).
GANDALF_GITHUB_PRIVATE_KEY_PATH=C:\Users\<you>\.secrets\gandalf.private-key.pem

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
GANDALF_FORCE_LOCAL_ONLY=0
# Agent execution mode: local_react (default, Gemma tools), cloud (Claude tools)
GANDALF_AGENT_MODE=local_react
# Optional separate upstream for /ws/voice proxy (if different tunnel/domain than API).
VOICE_GPU_URL=
# Gateway voice proxy cooldown (seconds) after upstream websocket failures.
VOICE_UPSTREAM_COOLDOWN_SEC=20

# Optional specialist delegation while keeping Gemma as primary orchestrator.
GANDALF_CLAUDE_SUBAGENT_ENABLED=1
CLAUDE_SUBAGENT_MODEL=claude-sonnet-4-6
# Deterministic delegation gate controls.
GANDALF_CLAUDE_SUBAGENT_TOKEN_THRESHOLD=9000
GANDALF_CLAUDE_SUBAGENT_ALLOWLIST=long context,document analysis,multi-file,codebase synthesis,second opinion,validation,refactor
GANDALF_CLAUDE_SUBAGENT_MAX_CALLS=6
GANDALF_CLAUDE_SUBAGENT_WINDOW_SEC=60
# Optional overrides and logging.
GANDALF_CLAUDE_SUBAGENT_FORCE=0
GANDALF_CLAUDE_SUBAGENT_AUDIT_LOG=phase3-agents/claude_subagent_audit.jsonl

# ── GitHub App (autonomous bot commits) ──────────────────────────────────────
GANDALF_GITHUB_APP_ID=<app-id>
GANDALF_GITHUB_INSTALLATION_ID=<installation-id>

# ── Lighting ──────────────────────────────────────────────────────────────────
GANDALF_ENABLE_LIGHTING=1
GANDALF_LIGHTING_ALIENFX=1
GANDALF_LIGHTING_CORSAIR=0
